# Polymarket APIs (no auth needed for market data)
# POLYMARKET_API_KEY=  # Only needed for trading, not surveillance

# External data sources
CONGRESS_API_KEY=         # Free key from api.congress.gov
COURTLISTENER_TOKEN=      # Free token from courtlistener.com
NEWSAPI_KEY=              # Free key from newsapi.org (100 req/day)

# Optional: Webhook URL for report delivery
# WEBHOOK_URL=https://hooks.slack.com/services/...

# Database path (default: data/prediction_market.db)
# DATABASE_PATH=data/prediction_market.db

# Log level
# LOG_LEVEL=INFO
